model Mentor {
  id                        String           @id @default(cuid())
  userId                    String           @unique
  name                      String
  bio                       String?
  expertise                 String[]
  credentials               String[]
  licenseNumber             String?
  licenseType               String?
  yearsOfExperience         Int?
  hourlyRate                Float?
  rating                    Float            @default(0)
  totalSessions             Int              @default(0)
  completedStackZenSessions Int              @default(0)
  isCertified               Boolean          @default(false)
  isVerified                Boolean          @default(false)
  isActive                  Boolean          @default(true)
  stripeConnectId           String?
  availability              Json?
  specialties               String[]
  languages                 String[]         @default(["English"])
  headshotUrl               String?
  licenseUrl                String?
  idUrl                     String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  user                      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resources                 MentorResource[]
  reviews                   MentorReview[]
  sessions                  MentorSession[]

  @@index([userId])
  @@index([isCertified])
  @@index([isVerified])
  @@index([rating])
  @@index([specialties])
}

model MentorSession {
  id                    String        @id @default(cuid())
  mentorId              String
  userId                String
  sessionType           SessionType
  status                SessionStatus @default(SCHEDULED)
  scheduledAt           DateTime
  duration              Int
  price                 Float
  platformFee           Float
  mentorPayout          Float
  meetingUrl            String?
  meetingId             String?
  notes                 String?
  rating                Int?
  feedback              String?
  stripePaymentIntentId String?
  stripeSessionId       String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  mentor                Mentor        @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([userId])
  @@index([sessionType])
  @@index([status])
  @@index([scheduledAt])
  @@index([stripePaymentIntentId])
}

model MentorReview {
  id          String   @id @default(cuid())
  mentorId    String
  userId      String
  sessionId   String?
  rating      Int
  comment     String?
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mentor      Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

model MentorResource {
  id          String       @id @default(cuid())
  mentorId    String
  title       String
  description String?
  type        ResourceType
  url         String?
  fileUrl     String?
  tags        String[]
  isPublic    Boolean      @default(false)
  downloads   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mentor      Mentor       @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([type])
  @@index([tags])
  @@index([isPublic])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  severity  String   @default("info")
  details   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  resource  String?
  user      User?    @relation(fields: [userId], references: [id])
}

/// Processed Stripe webhook events (idempotency; `id` is Stripe event id e.g. evt_…).
model StripeEvent {
  id        String   @id
  type      String
  createdAt DateTime
}

model LedgerEntry {
  id             String   @id
  userId         String
  fromAccountId  String?
  toGoalId       String?
  ruleId         String?
  transactionId  String?
  amount         Float
  currency       String   @default("USD")
  reason         String
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([transactionId])
  @@index([userId, createdAt])
}

model MoneyAccount {
  id             String        @id
  userId         String
  name           String
  type           AccountType
  provider       BankProvider  @default(NONE)
  providerRef    String?
  currency       String        @default("USD")
  currentBalance Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  User           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Transaction    Transaction[]

  @@index([userId])
}

model RuleAllocation {
  id          String      @id
  ruleId      String
  goalId      String
  weight      Float       @default(1)
  SavingsGoal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  SavingsRule SavingsRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([ruleId])
}

model Transaction {
  id           String       @id
  userId       String
  accountId    String
  occurredAt   DateTime
  postedAt     DateTime
  amount       Float
  currency     String       @default("USD")
  merchant     String?
  category     String?
  description  String?
  providerRef  String?
  isPending    Boolean      @default(false)
  hash         String       @unique
  createdAt    DateTime     @default(now())
  MoneyAccount MoneyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId, postedAt])
  @@index([userId, occurredAt])
}

model plan_counters {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar
  plan_code    plan_code @unique
  active_count Int       @default(0)
  max_allowed  Int?
  updated_at   DateTime  @default(now()) @db.Timestamp(6)

  @@index([plan_code], map: "idx_plan_counters_code")
}

