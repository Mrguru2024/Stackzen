// Mentor System Models for StackZen

model Mentor {
  id                    String   @id @default(cuid())
  userId                String   @unique
  name                  String
  bio                   String?
  expertise             String[]
  credentials           String[]
  licenseNumber         String?
  licenseType           String?  // Series 65, CFP, etc.
  yearsOfExperience     Int?
  hourlyRate            Float?
  rating                Float    @default(0)
  totalSessions         Int      @default(0)
  completedStackZenSessions Int  @default(0)
  isCertified           Boolean  @default(false)
  isVerified            Boolean  @default(false)
  isActive              Boolean  @default(true)
  stripeConnectId       String?
  availability          Json?    // Weekly schedule
  specialties           String[] // Financial planning, debt management, etc.
  languages             String[] @default(["English"])
  headshotUrl           String?
  licenseUrl            String?
  idUrl                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions              MentorSession[]
  reviews               MentorReview[]
  resources             MentorResource[]

  @@index([userId])
  @@index([isCertified])
  @@index([isVerified])
  @@index([rating])
  @@index([specialties])
}

model MentorSession {
  id                    String   @id @default(cuid())
  mentorId              String
  userId                String
  sessionType           SessionType
  status                SessionStatus @default(SCHEDULED)
  scheduledAt           DateTime
  duration              Int      // in minutes
  price                 Float
  platformFee           Float
  mentorPayout          Float
  meetingUrl            String?
  meetingId             String?
  notes                 String?
  rating                Int?
  feedback              String?
  stripePaymentIntentId String?
  stripeSessionId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  mentor                Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([userId])
  @@index([sessionType])
  @@index([status])
  @@index([scheduledAt])
  @@index([stripePaymentIntentId])
}

model MentorReview {
  id                    String   @id @default(cuid())
  mentorId              String
  userId                String
  sessionId             String?
  rating                Int
  comment               String?
  isAnonymous           Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  mentor                Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

model MentorResource {
  id                    String   @id @default(cuid())
  mentorId              String
  title                 String
  description           String?
  type                  ResourceType
  url                   String?
  fileUrl               String?
  tags                  String[]
  isPublic              Boolean  @default(false)
  downloads             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  mentor                Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([type])
  @@index([tags])
  @@index([isPublic])
}

enum SessionType {
  STACKZEN_SESSION
  DIRECT_BOOKING
  ZEN_PLUS_SESSION
}

enum SessionStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ResourceType {
  PDF
  VIDEO
  TEMPLATE
  CALCULATOR
  CHECKLIST
  GUIDE
} 