# next-auth@4 peer range lists Next 12–15; this app uses Next 16 (by design).
# Allow installs until an Auth.js / next-auth v5 migration; runtime works with webpack dev.
legacy-peer-deps=true

# PostCSS requires `nanoid/non-secure` via plain `require()`. Turbopack's Node evaluation
# does not apply `turbopack.resolveAlias` to that path, so `nanoid` must exist under the
# project root `node_modules` (pnpm otherwise keeps it only under `.pnpm/...`).
public-hoist-pattern[]=nanoid
