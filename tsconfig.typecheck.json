{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.d.ts",
    "app/api/webhooks/stripe/route.ts",
    "app/api/invoices/[invoiceId]/[id]/download/route.ts",
    "app/api/bank/exchange-token/route.ts",
    "app/api/admin/users/route.ts",
    "app/api/admin/devices/route.ts",
    "app/api/admin/devices/[deviceId]/trust/route.ts",
    "app/api/admin/devices/[deviceId]/revoke/route.ts",
    "app/api/jobs/route.ts",
    "app/api/jobs/[jobId]/route.ts",
    "app/api/jobs/[jobId]/deposit-invoice/route.ts",
    "app/api/jobs/[jobId]/final-invoice/route.ts",
    "app/api/quotes/[quoteId]/convert/route.ts",
    "app/api/clients/route.ts",
    "app/api/clients/[id]/route.ts",
    "app/api/invoices/route.ts",
    "lib/operational-state/reconcile-derived-attention.ts",
    "lib/workspace/priority-engine.ts",
    "app/api/operational-center/alerts/route.ts",
