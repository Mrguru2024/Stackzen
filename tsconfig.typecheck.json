    "lib/jobs/apply-status-from-payment.ts",
    "lib/api/production-gate.ts",
    "lib/api/require-auth.ts",
    "lib/api/require-admin.ts",
    "lib/auth-config.ts",
    "lib/stripe.ts",
    "lib/plaid.ts",
    "lib/prisma.ts",
    "lib/auth/privileged-users.ts",
    "lib/jobs/revenue.ts",
    "lib/jobs/deposit-status.ts",
    "lib/financial-events/events.ts",
    "lib/financial-events/query.ts",
    "app/api/financial-events/timeline/route.ts",
    "components/financial-events/FinancialTimelineView.tsx",
    "app/(dashboard)/financial-timeline/page.tsx",
    "components/JobDetail/index.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "tests/**",
    "__tests__/**",
    "__mocks__/**",
    "components/dev/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.tsx"
