# Authentication
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase (optional; used for Supabase Auth / client APIs — get values from project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase MCP (Cursor) — only if you use PAT auth instead of OAuth. Create a token at:
# https://supabase.com/dashboard/account/tokens — then set this in your OS or Cursor environment
# (not necessarily in this file; .env is not loaded into mcp.json remote servers). See .cursor/mcp-pat.template.json
# SUPABASE_ACCESS_TOKEN=

# Database — Supabase Postgres (Dashboard → Settings → Database).
# Pooled URL (6543) must include ?pgbouncer=true for Prisma. DIRECT_URL (5432) is required for migrations.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres"
PGDATABASE="dbname"
PGHOST="localhost"
PGPORT="5432"
PGUSER="user"
PGPASSWORD="password"

# Node Environment
NODE_ENV=development

# Dev performance (optional)
# PRISMA_LOG_QUERIES=true
# AUTH_DEBUG=true
# SUPABASE_MIDDLEWARE_REFRESH=false

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Configuration (for magic links)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="noreply@stackzen.com"
# Brevo (transactional email) — https://app.brevo.com/settings/keys/api
# Sender must be verified in Brevo (Settings → Senders & IP).
BREVO_API_KEY=
# Optional if EMAIL_FROM is unset: plain address or "StackZen <noreply@yourdomain.com>"
BREVO_SENDER_EMAIL=

# Redis Configuration (for session management)
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="StackZen"

# MET Repairs OS consumer integration (server-only — read-only financial API)
# Must match STACKZEN_API_KEY on metrepairs.com. Generate: npm run met-repairs:generate-key
MET_REPAIRS_API_URL="https://metrepairs.com"
MET_REPAIRS_API_KEY=""

# StackZen AI orchestration (server-only keys — never use NEXT_PUBLIC_ for these)
ENABLE_AI_FEATURES="true"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
GOOGLE_GENERATIVE_AI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
AI_REQUEST_TIMEOUT_MS="30000"
AI_MAX_FALLBACK_DEPTH="2"

# API Keys
PLAID_CLIENT_ID="your-plaid-client-id"
PLAID_SECRET="your-plaid-secret"
PLAID_ENV="sandbox"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Feature Flags
ENABLE_AI_FEATURES="true"
ENABLE_CHALLENGES="true"
ENABLE_GOALS="true"

# Stripe
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"

# Mentor live video (Daily.co) — optional; without DAILY_API_KEY demo URLs still work locally
DAILY_API_KEY=""
DAILY_ROOM_URL_TEMPLATE="https://your-subdomain.daily.co/{room}"

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_ID_FREE_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_FREE_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_FREE_LIFETIME="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_LIFETIME="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_YEARLY="price_xxxxxxxxxxxxx"

# Security Headers
SECURITY_HEADERS_ENABLED="true"
CSP_ENABLED="true"
CSP_REPORT_URI=""
HSTS_ENABLED="true"
SECURITY_STRICT_RATE_LIMIT="true"
ALLOWED_ORIGINS="https://stackzen.com,https://www.stackzen.com"

# Cloudflare Turnstile (bot protection — signup proof route; extend to login/reset in Phase 3)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Field-level encryption for Plaid tokens, TOTP secrets, and sensitive data (32+ byte secret; required in production)
BANK_TOKEN_ENCRYPTION_KEY=""

# Phase 3 — auth hardening
SESSION_HASH_PEPPER=""
ENABLE_WEBAUTHN="false"
LOGIN_GEO_ENABLED="false"

# Phase 4 — field encryption (production requires BANK_TOKEN_ENCRYPTION_KEY, 32+ chars)
ENCRYPT_CHAT_CONTENT="false"
ENCRYPT_ONBOARDING_SENSITIVE="false"

# Phase 6 — AI (requires POST /api/ai/consent before use; Turnstile on chat in production)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY and TURNSTILE_SECRET_KEY already documented above

# Phase 11 — See docs/security/DATA_CLASSIFICATION.md, SECURITY_RELEASE_CHECKLIST.md, AI_PRIVACY_CONTROLS.md

# Phase 9 — Admin security (MFA required for ADMIN/SUPER_ADMIN; 8h JWT / 30m idle — see lib/security/admin-policy.ts)
# Admin APIs: append ?includeSensitive=true to view full PII (audited as admin.view_sensitive)

# Phase 8 — Sentry (production monitoring; optional SENTRY_ENABLE_DEV=true locally)
# NEXT_PUBLIC_SENTRY_DSN, SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN documented below

# Monitoring
SENTRY_DSN="your-sentry-dsn"
LOG_LEVEL="info"
ENABLE_PERFORMANCE_MONITORING="true"

# Server Config
PORT=3000
SESSION_SECRET="your-session-secret"

# GitHub Integration for Feedback
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# Sentry Configuration
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"
SENTRY_ENABLE_DEV="false" # set true to report errors from local dev
STRIPE_PRICE_ID_FREE_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_FREE_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_LIFETIME="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_COACHING_SESSION="price_xxxxxxxxxxxxx"

# Adzuna API credentials
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ZipRecruiter API credentials
ZIPRECRUITER_API_KEY=your-ziprecruiter-api-key



# Indeed API credentials
INDEED_PUBLISHER_ID=your-indeed-publisher-id
INDEED_API_KEY=your-indeed-api-key

# Timing-coordination ICS calendar feed.
# Used to HMAC-sign read-only Google Calendar subscription URLs
# (/api/timing-coordination/calendar.ics?token=...). Must be >= 16 chars.
# Rotate by changing this value — all previously issued feed URLs become invalid.
STACKZEN_FEED_TOKEN_SECRET="please-set-a-long-random-string-here"


