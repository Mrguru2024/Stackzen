# Authentication
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase (optional; used for Supabase Auth / client APIs — get values from project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase MCP (Cursor) — only if you use PAT auth instead of OAuth. Create a token at:
# https://supabase.com/dashboard/account/tokens — then set this in your OS or Cursor environment
# (not necessarily in this file; .env is not loaded into mcp.json remote servers). See .cursor/mcp-pat.template.json
# SUPABASE_ACCESS_TOKEN=

# Database — Supabase Postgres (Dashboard → Settings → Database).
# Pooled URL (6543) must include ?pgbouncer=true for Prisma. DIRECT_URL (5432) is required for migrations.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres"
PGDATABASE="dbname"
PGHOST="localhost"
PGPORT="5432"
PGUSER="user"
PGPASSWORD="password"

# Node Environment
NODE_ENV=development

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Configuration (for magic links)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="noreply@stackzen.com"
# Resend — sends password reset emails for accounts with a bcrypt password in Postgres (signup flow).
RESEND_API_KEY=

# Redis Configuration (for session management)
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="StackZen"

# API Keys
PLAID_CLIENT_ID="your-plaid-client-id"
PLAID_SECRET="your-plaid-secret"
PLAID_ENV="sandbox"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Feature Flags
ENABLE_AI_FEATURES="true"
ENABLE_CHALLENGES="true"
ENABLE_GOALS="true"

# Stripe
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_ID_FREE_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_FREE_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_FREE_LIFETIME="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_LIFETIME="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_YEARLY="price_xxxxxxxxxxxxx"

# Security Headers
SECURITY_HEADERS_ENABLED="true"
CSP_ENABLED="true"
HSTS_ENABLED="true"

# Monitoring
SENTRY_DSN="your-sentry-dsn"
LOG_LEVEL="info"
ENABLE_PERFORMANCE_MONITORING="true"

# Server Config
PORT=3000
SESSION_SECRET="your-session-secret"

# GitHub Integration for Feedback
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# Sentry Configuration
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project" # Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_ID_FREE_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_FREE_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRO_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_LIFETIME="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_MONTHLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_ZEN_PLUS_YEARLY="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_COACHING_SESSION="price_xxxxxxxxxxxxx"

# Adzuna API credentials
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ZipRecruiter API credentials
ZIPRECRUITER_API_KEY=your-ziprecruiter-api-key



# Indeed API credentials
INDEED_PUBLISHER_ID=your-indeed-publisher-id
INDEED_API_KEY=your-indeed-api-key

# Timing-coordination ICS calendar feed.
# Used to HMAC-sign read-only Google Calendar subscription URLs
# (/api/timing-coordination/calendar.ics?token=...). Must be >= 16 chars.
# Rotate by changing this value — all previously issued feed URLs become invalid.
STACKZEN_FEED_TOKEN_SECRET="please-set-a-long-random-string-here"


